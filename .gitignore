# Rust / Tauri build artifacts
/src-tauri/target/
**/*.rs.bk

# Local runtime/config (these live in the OS app-config dir, but never commit
# them if a copy ends up in the tree — they can contain bot tokens / IDs).
bots.json
status.json
*.corrupt-*
*.tmp
*.tmp-*

# macOS
.DS_Store
.AppleDouble
.LSOverride
# NOTE: the usual "Icon?" rule for the legacy macOS resource file is omitted on
# purpose — with core.ignorecase=true it also matches the src-tauri/icons/
# directory, which silently kept the committed icon set out of the repo.

# Editor / IDE
.idea/
.vscode/
*.swp
*~

# Node (in case a frontend toolchain is added later)
node_modules/
dist/
